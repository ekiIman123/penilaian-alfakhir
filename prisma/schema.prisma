generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Evaluator {
  id          String       @id @default(cuid())
  name        String       @unique
  evaluations Evaluation[]
  createdAt   DateTime     @default(now())
}

model Teacher {
  id          String       @id @default(cuid())
  name        String       @unique
  role        String       @default("guru")   // "guru" | "staff"
  evaluations Evaluation[]
  createdAt   DateTime     @default(now())
}

model Evaluation {
  id          String    @id @default(cuid())
  evaluatorId String
  teacherId   String
  evaluator   Evaluator @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
  teacher     Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  scores      String    // JSON string: { criterionId: 1-4 }
  catatan     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([evaluatorId, teacherId])
}

model OrgSettings {
  id            String   @id @default("default")
  yayasanName   String   @default("YAYASAN AL FAKHIR")
  schoolName    String   @default("SMP AL FAKHIR JAKARTA SELATAN")
  address       String   @default("Jl. Ciledug Raya, Jakarta Selatan")
  phone         String   @default("")
  city          String   @default("Jakarta")
  periodLabel   String   @default("Semester Ganjil 2025/2026")
  kepalaSekolah String   @default("")
  ketuaName     String   @default("")
  ketuaTitle    String   @default("Ketua Balitbang SDM")
  logoBase64    String?
  updatedAt     DateTime @updatedAt
}
