generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id           String       @id @default(cuid())
  name         String
  role         String       @default("guru")
  lembaga      String       @default("alfakhir")
  divisi       String?
  finalCatatan String?
  evaluations  Evaluation[]
  createdAt    DateTime     @default(now())

  @@unique([name, role, lembaga])
}

model Evaluator {
  id          String       @id @default(cuid())
  name        String
  lembaga     String       @default("alfakhir")
  role        String       @default("evaluator")
  divisi      String?
  accessCode  String?      @unique
  evaluations Evaluation[]
  createdAt   DateTime     @default(now())

  @@unique([name, lembaga])
}

model Evaluation {
  id          String    @id @default(cuid())
  evaluatorId String
  employeeId  String
  lembaga     String    @default("alfakhir")
  rubricType  String    @default("standard")
  evaluator   Evaluator @relation(fields: [evaluatorId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  scores      String
  catatan     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([evaluatorId, employeeId])
}

model OrgSettings {
  id                     String   @id
  lembaga                String   @default("alfakhir")
  yayasanName            String   @default("YAYASAN AL FAKHIR")
  schoolName             String   @default("SMP AL FAKHIR JAKARTA SELATAN")
  address                String   @default("Jl. Ciledug Raya, Jakarta Selatan")
  phone                  String   @default("")
  city                   String   @default("Jakarta")
  periodLabel            String   @default("Semester Ganjil 2025/2026")
  kepalaSekolah          String   @default("")
  kepalaTitle            String   @default("Kepala SMP Islam Modern Al Fakhir")
  kepalaSignatureBase64  String?
  signer2Name            String   @default("")
  signer2Title           String   @default("Deputi Litbang & SDM Al Fakhir")
  signer2SignatureBase64 String?
  ketuaName              String   @default("")
  ketuaTitle             String   @default("Owner & Founder Al Fakhir")
  ketuaSignatureBase64   String?
  logoBase64             String?
  updatedAt              DateTime @updatedAt
}
